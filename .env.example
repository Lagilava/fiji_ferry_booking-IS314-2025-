# Django Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated scheme+host origins. Set to your real domain(s) in production.
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Optional extra CORS origins (tunnels, CDNs); merged with CSRF_TRUSTED_ORIGINS.
CORS_ALLOWED_ORIGINS=

# Database Configuration
DB_NAME=fiji_ferry_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# Email Configuration (for notifications)
# Local/dev: Gmail SMTP works fine.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_password
# Production on hosts that block outbound SMTP (e.g. Render): set BREVO_API_KEY
# and email is sent via Brevo's HTTPS API instead. Takes priority over SMTP.
# Get a key at https://app.brevo.com (Settings > SMTP & API > API Keys) and
# verify your sender address (DEFAULT_FROM_EMAIL) under Senders.
BREVO_API_KEY=

# Payment Gateway (placeholder for future integration)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# SMS / WhatsApp notifications (Twilio). Leave blank to disable (email only).
# In Fiji, SMS/WhatsApp reach travellers far more reliably than email.
#   SMS_CHANNELS: sms | whatsapp | both
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
SMS_CHANNELS=sms
SMS_DEFAULT_COUNTRY_CODE=679
