      "url": "/bookings/departures/",
      "icons": [{ "src": "/static/android-chrome-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "My Bookings",
      "url": "/bookings/history/",
      "icons": [{ "src": "/static/android-chrome-192x192.png", "sizes": "192x192" }]
    }
  ]
}
